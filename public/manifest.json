{
  "name": "SY INC. MSO 통합 시스템",
  "short_name": "MSO",
  "description": "병원 경영 통합 관리 시스템",
  "id": "/main",
  "start_url": "/main",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#ffffff",
  "theme_color": "#2563eb",
  "orientation": "portrait-primary",
  "icons": [
    { "src": "/sy-logo.png", "sizes": "72x72",   "type": "image/png", "purpose": "any" },
    { "src": "/sy-logo.png", "sizes": "96x96",   "type": "image/png", "purpose": "any" },
    { "src": "/sy-logo.png", "sizes": "128x128", "type": "image/png", "purpose": "any" },
    { "src": "/sy-logo.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/sy-logo.png", "sizes": "152x152", "type": "image/png", "purpose": "any" },
    { "src": "/sy-logo.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/sy-logo.png", "sizes": "384x384", "type": "image/png", "purpose": "any" },
    { "src": "/sy-logo.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/sy-logo.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/sy-logo.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        { "name": "files", "accept": ["image/*", "video/*", "application/pdf", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx", ".txt", ".zip"] }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "채팅",
      "short_name": "채팅",
      "url": "/main?open_menu=채팅",
      "icons": [{ "src": "/sy-logo.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "게시판",
      "short_name": "게시판",
      "url": "/main?open_menu=게시판",
      "icons": [{ "src": "/sy-logo.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "전자결재",
      "short_name": "결재",
      "url": "/main?open_menu=전자결재",
      "icons": [{ "src": "/sy-logo.png", "sizes": "96x96", "type": "image/png" }]
    }
  ]
}
